# GitHub API Read-only Personal Access Token (PAT)
# Go to GitHub settings -> Developer settings -> Personal access tokens (fine-grained or classic)
# Grants: Read-only access to Repository metadata and Repository contents
GITHUB_TOKEN=your_github_token_here

# Secret API key used to protect your custom proxy server gh.rblez.com
# Agents/clients must supply this via 'Authorization: Bearer <key>' or '?key=<key>'
API_KEY=your_secure_proxy_api_key_here

# Server Port (default is 8000)
PORT=8000
